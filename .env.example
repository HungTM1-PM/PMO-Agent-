# ── Anthropic (bắt buộc cho phân tích AI) ──────────────────────────────────
CLAUDE_API_KEY=

# Model Messages API (tùy chọn — mặc định: claude-sonnet-4-6)
# Xem: https://docs.anthropic.com/en/docs/about-claude/models/overview
CLAUDE_MODEL=claude-sonnet-4-6

# ── SMTP (gửi email báo cáo) ───────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Director nhận báo cáo PM + BOD
DIRECTOR_EMAIL=
DIRECTOR_NAME=

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3000
# URL công khai sau deploy (link trong email)
PUBLIC_URL=http://localhost:3000

# ── MySQL (bỏ trống MYSQL_HOST = dùng bộ nhớ tạm, phù hợp dev/test) ───────
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=pmo_agent

# ── Auth (JWT) ────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d
# true = cho phép đăng ký công khai (role pm); production có thể tắt
REGISTER_OPEN=true

# Tài khoản admin lần đầu (chỉ khi DB trống / migrate xong)
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
