{
  "name": "pmo-agent",
  "version": "1.0.0",
  "description": "PMO Customer/People Management – Teams Checklist & Claude Analysis",
  "main": "server/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "db:migrate": "node server/migrate.js",
    "clean": "rm -rf coverage playwright-report test-results",
    "test": "NODE_ENV=test node --no-warnings node_modules/jest/bin/jest.js --coverage",
    "test:unit": "NODE_ENV=test node --no-warnings node_modules/jest/bin/jest.js tests/unit --coverage",
    "test:integration": "NODE_ENV=test node --no-warnings node_modules/jest/bin/jest.js tests/integration --coverage",
    "test:watch": "NODE_ENV=test node --no-warnings node_modules/jest/bin/jest.js --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:perf": "node scripts/perf-with-server.js",
    "test:perf:client": "node scripts/perf-smoke.js",
    "test:all": "npm run test && npm run test:e2e && npm run test:perf"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.0",
    "node-fetch": "^2.7.0",
    "nodemailer": "^8.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  }
}
